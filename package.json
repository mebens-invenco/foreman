{
  "name": "foreman",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "pnpm": "11.3.0"
  },
  "type": "module",
  "bin": {
    "foreman": "dist/cli.js"
  },
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "ui:dev": "pnpm --filter @foreman/ui dev",
    "foreman": "node dist/cli.js",
    "start": "node dist/cli.js",
    "build": "pnpm run build:server && pnpm run build:ui",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ui": "pnpm --filter @foreman/ui build",
    "check": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.json && pnpm --filter @foreman/ui typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:skills": "./scripts/install-skills.sh"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^14.0.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "fastembed": "^2.1.0",
    "fastify": "^5.9.0",
    "gray-matter": "^4.0.3",
    "ulid": "^3.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  }
}
