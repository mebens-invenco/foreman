{
  "name": "foreman",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "ui"
  ],
  "type": "module",
  "bin": {
    "foreman": "dist/cli.js"
  },
  "scripts": {
    "dev": "yarn build && yarn start",
    "ui:dev": "yarn workspace @foreman/ui dev",
    "foreman": "node dist/cli.js",
    "start": "node dist/cli.js",
    "build": "yarn build:server && yarn build:ui",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ui": "yarn workspace @foreman/ui build",
    "check": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.json && yarn workspace @foreman/ui typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^14.0.0",
    "dotenv": "^17.2.2",
    "fast-glob": "^3.3.3",
    "fastify": "^5.6.0",
    "gray-matter": "^4.0.3",
    "ulid": "^3.0.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
